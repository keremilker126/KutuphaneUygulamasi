@model List<YayinEvi>

<div class="container mt-4">

    <div class="card shadow-lg border-0">

        <div class="card-header bg-secondary text-white d-flex justify-content-between align-items-center">
            <h4 class="mb-0">🏢 Yayın Evleri</h4>

            <a href="/YayinEvi/Ekle" class="btn btn-light btn-sm">
                ➕ Yeni Yayın Evi Ekle
            </a>
        </div>

        <div class="card-body">

            <table class="table table-hover table-striped align-middle">

                <thead class="table-dark">
                    <tr>
                        <th>#</th>
                        <th>Yayın Evi Adı</th>
                        <th>Adres</th>
                        <th class="text-center">İşlemler</th>
                    </tr>
                </thead>

                <tbody>

                    @foreach(var yayinEvi in Model)
                    {
                        <tr>

                            <td>
                                <span class="badge bg-secondary">
                                    @yayinEvi.Id
                                </span>
                            </td>

                            <td>
                                <strong>@yayinEvi.Ad</strong>
                            </td>

                            <td>
                                @yayinEvi.Adres
                            </td>

                            <td class="text-center">

                                <a href="/YayinEvi/Duzenle/@yayinEvi.Id"
                                   class="btn btn-sm btn-warning">
                                    ✏ Düzenle
                                </a>

                                <a href="/YayinEvi/Sil/@yayinEvi.Id"
                                   class="btn btn-sm btn-danger">
                                    🗑 Sil
                                </a>

                            </td>

                        </tr>
                    }

                </tbody>

            </table>

        </div>

    </div>

</div>