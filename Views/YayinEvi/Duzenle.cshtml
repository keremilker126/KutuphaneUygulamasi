@model YayinEvi

<div class="container mt-4">

    <div class="card shadow-sm">

        <div class="card-header bg-primary text-white">
            <h5 class="mb-0">
                <i class="bi bi-building"></i> Yayın Evini Düzenle
            </h5>
        </div>

        <div class="card-body">

            <form asp-action="Duzenle" asp-controller="YayinEvi" method="post">

                <input type="hidden" name="Id" value="@Model.Id">

                <div class="row">

                    <div class="col-md-6">
                        <div class="mb-3">
                            <label class="form-label fw-bold">Yayın Evi Adı</label>

                            <input 
                                type="text"
                                class="form-control"
                                name="Ad"
                                value="@Model.Ad"
                                placeholder="Yayın evinin adını giriniz..."
                                required>

                        </div>
                    </div>

                </div>

                <div class="row">

                    <div class="col-md-8">

                        <div class="mb-3">
                            <label class="form-label fw-bold">Adres</label>

                            <input 
                                type="text"
                                class="form-control"
                                name="Adres"
                                value="@Model.Adres"
                                placeholder="Yayın evinin adresini giriniz...">

                        </div>

                    </div>

                </div>

                <div class="d-flex justify-content-end gap-2 mt-3">

                    <a asp-action="Index" class="btn btn-outline-secondary">
                        <i class="bi bi-arrow-left"></i> Geri
                    </a>

                    <button type="submit" class="btn btn-success">
                        <i class="bi bi-check-lg"></i> Güncelle
                    </button>

                </div>

            </form>

        </div>

    </div>

</div>