@model Sinif

<div class="container mt-4">
    <h4>Yeni Sınıf Oluştur</h4>
    <hr />
    <div class="row">
        <div class="col-md-4">
            <form asp-action="Ekle" method="post">
                <div class="form-group mb-3">
                    <label class="control-label">Sınıf Adı</label>
                    <input asp-for="Ad" class="form-control" placeholder="Örn: 10-A" />
                </div>
                <div class="form-group mb-3">
                    <label class="control-label">Seviye</label>
                    <input asp-for="Seviye" class="form-control" placeholder="Örn: 9" />
                </div>
                <button type="submit" class="btn btn-success">Kaydet</button>
                <a asp-action="Index" class="btn btn-secondary">İptal</a>
            </form>
        </div>
    </div>
</div>