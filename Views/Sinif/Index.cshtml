@model List<Sinif>

<div class="container mt-4">
    <div class="card shadow-lg border-0">
        <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
            <h4 class="mb-0">🏫 Sınıf Listesi</h4>
            <a asp-action="Ekle" class="btn btn-light btn-sm fw-bold text-primary">
                <i class="bi bi-plus-circle"></i> Yeni Sınıf Ekle
            </a>
        </div>

        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-hover align-middle">
                    <thead class="table-light">
                        <tr>
                            <th style="width: 40%">Sınıf Adı</th>
                            <th style="width: 30%">Seviye / Bölüm</th>
                            <th style="width: 30%" class="text-center">İşlemler</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model) {
                            <tr>
                                <td>
                                    <div class="d-flex align-items-center">
                                        <div class="avatar-sm me-3 bg-soft-primary text-primary text-center rounded py-1 px-2" style="background-color: #e7f1ff;">
                                            <i class="bi bi-door-open-fill"></i>
                                        </div>
                                        <span class="fw-bold">@item.Ad</span>
                                    </div>
                                </td>
                                <td>
                                    <span class="badge bg-info text-dark">@item.Seviye. Sınıf</span>
                                </td>
                                <td class="text-center">
                                    <a asp-action="Duzenle" asp-route-id="@item.Id" class="btn btn-sm btn-outline-warning me-1">
                                        <i class="bi bi-pencil"></i> Düzenle
                                    </a>
                                    <a asp-action="Sil" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger" onclick="return confirm('Emin misiniz?')">
                                        <i class="bi bi-trash"></i> Sil
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>