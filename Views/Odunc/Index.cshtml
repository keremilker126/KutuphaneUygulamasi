@model List<Odunc>

<div class="container mt-4">

    <div class="card shadow-lg border-0">

        <div class="card-header bg-info text-white d-flex justify-content-between align-items-center">
            <h4 class="mb-0">📖 Ödünç Kitaplar</h4>

            <a href="/Odunc/KitapVer" class="btn btn-light btn-sm">
                ➕ Kitap Ver
            </a>
        </div>

        <div class="card-body">

            <table class="table table-hover table-striped align-middle">

                <thead class="table-dark">
                    <tr>
                        <th>#</th>
                        <th>Üye</th>
                        <th>Kitap</th>
                        <th>Veriliş Tarihi</th>
                        <th>Teslim Edilmesi Gereken</th>
                        <th>Teslim Tarihi</th>
                        <th>Durum</th>
                        <th>İşlem</th>
                    </tr>
                </thead>

                <tbody>

                    @foreach (var odunc in Model)
                    {
                        <tr>

                            <td>
                                <span class="badge bg-secondary">
                                    @odunc.Id
                                </span>
                            </td>

                            <td>
                                @odunc.UyeId
                            </td>

                            <td>
                                @odunc.KitapId
                            </td>

                            <td>
                                @odunc.VerilisTarihi.ToShortDateString()
                            </td>

                            <td>
                                @odunc.GetirmesiIstenenTarih.ToShortDateString()
                            </td>

                            <td>
                                @(odunc.TeslimTarihi.HasValue 
                                    ? odunc.TeslimTarihi.Value.ToShortDateString() 
                                    : "Henüz Getirilmedi")
                            </td>

                            <td>
                                @if (odunc.Durum)
                                {
                                    <span class="badge bg-success">
                                        Teslim Edildi
                                    </span>
                                }
                                else
                                {
                                    <span class="badge bg-warning text-dark">
                                        Okunuyor
                                    </span>
                                }
                            </td>

                            <td>

                                <a asp-action="KitabiAl"
                                   asp-controller="Odunc"
                                   asp-route-id="@odunc.Id"
                                   class="btn btn-sm btn-primary">
                                    📥 Kitabı Al
                                </a>

                                <a href="/Odunc/Sil/@odunc.Id"
                                   class="btn btn-sm btn-danger">
                                    🗑 Sil
                                </a>

                            </td>

                        </tr>
                    }

                </tbody>

            </table>

        </div>

    </div>

</div>