@model List<Uye>

<div class="container mt-4">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h3>👥 Üye Listesi</h3>

        <a href="/Uye/Ekle/" class="btn btn-success">
            ➕ Yeni Üye Ekle
        </a>
    </div>

    <div class="row">

        @foreach (var uye in Model)
        {
            <div class="col-md-4 mb-4">

                <div class="card shadow-sm h-100">

                    <div class="card-body">

                        <h5 class="card-title">
                            <span class="badge bg-secondary">@uye.Id</span>
                            @uye.Ad @uye.Soyad
                        </h5>

                        <h6 class="card-subtitle mb-2 text-muted">
                            📧 @uye.Eposta
                        </h6>

                    
                        
                        <p class="card-text">
                            🎓 @uye.SinifAdi <br />
                            📞 @uye.Telefon
                        </p>

                
                        <div class="d-flex justify-content-between">

                            <a href="/Uye/Duzenle/@uye.Id" class="btn btn-sm btn-warning">
                                ✏ Düzenle
                            </a>

                            <a href="/Uye/Sil/@uye.Id" class="btn btn-sm btn-danger">
                                🗑 Sil
                            </a>

                        </div>

                    </div>

                </div>

            </div>
        }

    </div>

</div>