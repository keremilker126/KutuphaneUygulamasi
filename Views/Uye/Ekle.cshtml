<div class="container mt-4">

    <div class="card shadow-sm">

        <div class="card-header bg-success text-white">
            <h5 class="mb-0">
                <i class="bi bi-person-plus"></i> Yeni Üye Ekle
            </h5>
        </div>

        <div class="card-body">

            <form asp-action="Ekle" method="post">
    
                <div class="row">

                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-bold">Ad</label>
                        <input 
                            type="text"
                            name="Ad"
                            class="form-control"
                            placeholder="Üyenin adı"
                            required />
                    </div>

                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-bold">Soyad</label>
                        <input 
                            type="text"
                            name="Soyad"
                            class="form-control"
                            placeholder="Üyenin soyadı"
                            required />
                    </div>

                </div>
    
                <div class="row">

                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-bold">E-posta</label>
                        <input 
                            type="email"
                            name="Eposta"
                            class="form-control"
                            placeholder="ornek@mail.com" />
                    </div>
    
                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-bold">Telefon</label>
                        <input 
                            type="tel"
                            name="Telefon"
                            class="form-control"
                            placeholder="05xx xxx xx xx" />
                    </div>

                </div>
    
                <div class="d-flex justify-content-end gap-2 mt-3">

                    <a asp-action="Index" class="btn btn-outline-secondary">
                        <i class="bi bi-arrow-left"></i> Geri
                    </a>

                    <button type="submit" class="btn btn-success">
                        <i class="bi bi-check-lg"></i> Üyeyi Kaydet
                    </button>

                </div>

            </form>

        </div>

    </div>

</div>