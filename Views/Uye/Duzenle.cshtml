@model Uye

<div class="container mt-4">

    <div class="card shadow-sm">

        <div class="card-header bg-primary text-white">
            <h5 class="mb-0">
                <i class="bi bi-person-gear"></i> Üye Bilgilerini Düzenle
            </h5>
        </div>

        <div class="card-body">

            <form asp-action="Duzenle" method="post">

                <input type="hidden" name="Id" value="@Model.Id" />

                <div class="row">

                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-bold">Ad</label>
                        <input type="text" name="Ad" class="form-control" value="@Model.Ad" placeholder="Üyenin adı"
                               required />
                    </div>

                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-bold">Soyad</label>
                        <input type="text" name="Soyad" class="form-control" value="@Model.Soyad"
                               placeholder="Üyenin soyadı" required />
                    </div>

                </div>

                <div class="row">

                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-bold">E-posta</label>
                        <input type="email" name="Eposta" class="form-control" value="@Model.Eposta"
                               placeholder="ornek@mail.com" />
                    </div>

                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-bold">Telefon</label>
                        <input type="tel" name="Telefon" class="form-control" value="@Model.Telefon"
                               placeholder="05xx xxx xx xx" />
                    </div>

                </div>
                <div class="mb-3">
                    <label class="form-label fw-bold">Sınıf</label>
                    <select name="SinifAdi" class="form-control">
                        <option value="">Seçiniz</option>

                        @foreach (var i in ViewBag.sinif)
                        {
                            var sinifAdi = $"{i.Ad}";
                            <option value="@sinifAdi" selected="@(Model.SinifAdi == sinifAdi)">
                                @sinifAdi
                            </option>
                        }
                    </select>
                </div>

                <div class="d-flex justify-content-end gap-2 mt-3">

                    <a asp-action="Index" class="btn btn-outline-secondary">
                        <i class="bi bi-arrow-left"></i> Geri
                    </a>

                    <button type="submit" class="btn btn-success">
                        <i class="bi bi-check-lg"></i> Güncelle
                    </button>

                </div>

            </form>

        </div>

    </div>

</div>