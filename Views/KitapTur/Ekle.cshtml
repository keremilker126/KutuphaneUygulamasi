<div class="container mt-4">

    <div class="card shadow-sm">

        <div class="card-header bg-primary text-white d-flex align-items-center">
            <i class="bi bi-bookmark-plus me-2"></i>
            <h5 class="mb-0">Yeni Kitap Türü Ekle</h5>
        </div>

        <div class="card-body">

            <form asp-action="Ekle" asp-controller="KitapTur" method="post">

                <div class="row">

                    <div class="col-md-6 col-lg-4">

                        <div class="mb-3">
                            <label class="form-label fw-bold">Tür Adı</label>

                            <input 
                                type="text"
                                class="form-control form-control-lg"
                                name="Ad"
                                placeholder="Kitap türü giriniz..."
                                required>

                        </div>

                    </div>

                </div>

                <div class="d-flex justify-content-end gap-2 mt-4">

                    <a asp-action="Index" asp-controller="KitapTur" class="btn btn-outline-secondary">
                        <i class="bi bi-arrow-left"></i> Geri
                    </a>

                    <button type="submit" class="btn btn-success">
                        <i class="bi bi-check-lg"></i> Kaydet
                    </button>

                </div>

            </form>

        </div>

    </div>

</div>