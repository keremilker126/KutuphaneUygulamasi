<div class="container mt-4">

    <div class="card shadow-sm">

        <div class="card-header bg-success text-white">
            <h5 class="mb-0">
                <i class="bi bi-person-plus"></i> Yeni Yazar Ekle
            </h5>
        </div>

        <div class="card-body">

            <form asp-action="Ekle" asp-controller="Yazar" method="post">

                <div class="row">

                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-bold">Ad</label>

                        <input
                            type="text"
                            name="Ad"
                            class="form-control"
                            placeholder="Yazarın adı"
                            required />
                    </div>

                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-bold">Soyad</label>

                        <input
                            type="text"
                            name="Soyad"
                            class="form-control"
                            placeholder="Yazarın soyadı"
                            required />
                    </div>

                </div>

                <div class="mb-3">

                    <label class="form-label fw-bold">Biyografi</label>

                    <textarea
                        name="Biyografi"
                        class="form-control"
                        rows="5"
                        placeholder="Yazar hakkında kısa bilgi..."></textarea>

                </div>

                <div class="d-flex justify-content-end gap-2 mt-3">

                    <a asp-action="Index" asp-controller="Yazar" class="btn btn-outline-secondary">
                        <i class="bi bi-arrow-left"></i> Geri
                    </a>

                    <button type="submit" class="btn btn-success">
                        <i class="bi bi-check-lg"></i> Yazarı Kaydet
                    </button>

                </div>

            </form>

        </div>

    </div>

</div>