@model List<Yazar>

<div class="container mt-4">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h3>✍️ Yazarlar</h3>

        <a href="/Yazar/Ekle" class="btn btn-success">
            ➕ Yeni Yazar Ekle
        </a>
    </div>

    <div class="row">

        @foreach (var yazar in Model)
        {
            <div class="col-md-4 mb-4">

                <div class="card shadow-sm h-100">

                    <div class="card-body">

                        <h5 class="card-title">
                            <span class="badge bg-secondary">@yazar.Id</span>
                            @yazar.Ad @yazar.Soyad
                        </h5>

                        <h6 class="card-subtitle mb-2 text-muted">
                            📚 Yazar
                        </h6>

                        <p class="card-text">
                            @yazar.Biyografi
                        </p>

                        <div class="d-flex justify-content-between">

                            <a href="/Yazar/Duzenle/@yazar.Id"
                               class="btn btn-sm btn-warning">
                                ✏ Düzenle
                            </a>

                            <a href="/Yazar/Sil/@yazar.Id"
                               class="btn btn-sm btn-danger">
                                🗑 Sil
                            </a>

                        </div>

                    </div>

                </div>

            </div>
        }

    </div>

</div>